{
  "type": "object",
  "properties": {
    "proNumber": {
      "type": "string",
      "description": "ArcBest PRO (shipment) number",
      "example": "PRO-123456789"
    },
    "bolNumber": {
      "type": "string",
      "description": "Bill of Lading number",
      "example": "BOL-20260419-001"
    },
    "status": {
      "type": "string",
      "description": "Shipment status",
      "enum": [
        "BOOKED",
        "PICKED_UP",
        "IN_TRANSIT",
        "OUT_FOR_DELIVERY",
        "DELIVERED",
        "EXCEPTION"
      ],
      "example": "BOOKED"
    },
    "quoteNumber": {
      "type": "string",
      "description": "Rate quote number used for booking",
      "example": "Q-20260419-001"
    }
  },
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/arcbest/refs/heads/main/json-structure/arcbest-api-shipment-structure.json",
  "name": "Shipment"
}